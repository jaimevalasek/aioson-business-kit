{
  "agent_id": "dev",
  "version": "1.0",
  "display_name": "Dev",
  "capabilities": [
    {
      "id": "implement_feature",
      "category": "create",
      "description": "Implement code changes according to spec and architecture.",
      "inputs": [
        { "type": "artifact", "path_pattern": ".aioson/context/spec-{slug}.md", "required": false },
        { "type": "artifact", "path_pattern": ".aioson/context/implementation-plan-{slug}.md", "required": false },
        { "type": "gate", "path_pattern": "gate:C", "required": false }
      ],
      "outputs": [
        { "type": "artifact", "path_pattern": "src/**/*" },
        { "type": "artifact", "path_pattern": "tests/**/*" },
        { "type": "state", "path_pattern": ".aioson/context/dev-state.md" }
      ]
    },
    {
      "id": "refactor_code",
      "category": "transform",
      "description": "Refactor existing code while preserving behavior.",
      "inputs": [
        { "type": "artifact", "path_pattern": ".aioson/context/discovery.md", "required": false }
      ],
      "outputs": [
        { "type": "artifact", "path_pattern": "src/**/*" }
      ]
    },
    {
      "id": "reflect_memory",
      "category": "transform",
      "description": "Update bootstrap/*.md after a relevant session by consuming reflect-prompt.json and running memory:reflect-commit.",
      "inputs": [
        { "type": "artifact", "path_pattern": ".aioson/runtime/reflect-prompt.json", "required": true },
        { "type": "artifact", "path_pattern": ".aioson/context/bootstrap/*.md", "required": false }
      ],
      "outputs": [
        { "type": "artifact", "path_pattern": ".aioson/context/bootstrap/current-state.md" },
        { "type": "artifact", "path_pattern": ".aioson/context/bootstrap/how-it-works.md" },
        { "type": "artifact", "path_pattern": ".aioson/context/bootstrap/what-it-does.md" },
        { "type": "event", "path_pattern": "runtime:memory_reflect_committed" }
      ],
      "trigger": "post_agent_done",
      "tier": "tier2_notified"
    }
  ],
  "autonomy_modes": ["guarded", "trusted"],
  "default_mode": "guarded",
  "supported_tools": ["codex", "claude", "gemini", "opencode"],
  "risk_profile": "medium"
}
