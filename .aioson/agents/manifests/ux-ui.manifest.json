{
  "agent_id": "ux-ui",
  "version": "1.0",
  "display_name": "UI/UX",
  "capabilities": [
    {
      "id": "design_ui_spec",
      "category": "create",
      "description": "Produce UI specification and visual direction for the approved scope.",
      "inputs": [
        { "type": "artifact", "path_pattern": ".aioson/context/architecture.md", "required": true },
        { "type": "artifact", "path_pattern": ".aioson/context/prd.md", "required": false },
        { "type": "artifact", "path_pattern": ".aioson/context/prd-{slug}.md", "required": false }
      ],
      "outputs": [
        { "type": "artifact", "path_pattern": ".aioson/context/ui-spec.md" }
      ]
    }
  ],
  "autonomy_modes": ["guarded"],
  "default_mode": "guarded",
  "supported_tools": ["codex", "claude", "gemini", "opencode"],
  "risk_profile": "medium"
}
