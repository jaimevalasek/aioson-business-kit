{
  "version": "1.1",
  "mode": "trusted",
  "shell_allowed": [
    "git diff *",
    "git log *",
    "git status",
    "git show *",
    "git rev-parse *",
    "ls *",
    "cat *",
    "head *",
    "tail *",
    "wc *",
    "grep *",
    "rg *",
    "find . *"
  ],
  "aioson_allowed": [
    "preflight",
    "preflight:context",
    "context:health",
    "context:validate",
    "context:pack",
    "context:load",
    "memory:status",
    "memory:summary",
    "memory:search",
    "workflow:status",
    "runtime:emit",
    "agent:done",
    "brain:query",
    "doctor",
    "memory:reflect-prepare",
    "memory:reflect-commit",
    "memory:refresh",
    "memory:archive",
    "memory:restore",
    "memory:trim",
    "workflow:next",
    "workflow:heal",
    "live:handoff",
    "live:close",
    "dossier:add-codemap",
    "dossier:add-finding",
    "dossier:link-rule",
    "notify"
  ],
  "shell_denied": [
    "git push *",
    "git reset --hard *",
    "git checkout -- *",
    "rm -rf *",
    "npm publish *",
    "curl * | sh",
    "curl * | bash",
    "rm -rf /",
    "*>*"
  ],
  "aioson_denied": [
    "cloud:publish:*",
    "genome:publish",
    "skill:publish",
    "squad:publish"
  ],
  "requires_tty": false
}
